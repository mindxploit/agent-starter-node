# =============================================
# LiveKit Agent - Self-hosted (no LiveKit Cloud)
# =============================================
# Copy to .env.local and fill in your values.

# --- LiveKit Server (self-hosted) ---
# Your LiveKit server WebSocket URL (e.g. wss://your-livekit.example.com)
LIVEKIT_URL=
# API key from your LiveKit server config
LIVEKIT_API_KEY=
# API secret from your LiveKit server config
LIVEKIT_API_SECRET=

# --- STT: Deepgram ---
# Get key: https://console.deepgram.com/
DEEPGRAM_API_KEY=

# --- TTS: Cartesia ---
# Get key: https://play.cartesia.ai/keys
CARTESIA_API_KEY=

# --- LLM + TTS: OpenAI ---
# Get key: https://platform.openai.com/api-keys
# Used for: chat completions (gpt-4o), TTS (gpt-4o-mini-tts), RAG embeddings
OPENAI_API_KEY=

# --- RAG: Qdrant (optional if using RAG) ---
# Default: http://localhost:6333
QDRANT_URL=
# Optional: if Qdrant requires auth
QDRANT_API_KEY=
